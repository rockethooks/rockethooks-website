---
import SectionHeading from '@components/shared/SectionHeading.astro';
import TestimonialCard from './TestimonialCard.astro';
import { testimonials } from '@data/testimonials';
---

<section class="bg-neutral-50 py-16 sm:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <SectionHeading
      overline="Testimonials"
      title="Trusted by engineering teams"
      subtitle="Hear from developers who replaced polling scripts with real-time event streams."
    />

    <div class="grid gap-6 sm:grid-cols-2">
      {testimonials.map((testimonial) => (
        <TestimonialCard
          quote={testimonial.quote}
          name={testimonial.name}
          role={testimonial.role}
          company={testimonial.company}
        />
      ))}
    </div>
  </div>
</section>
