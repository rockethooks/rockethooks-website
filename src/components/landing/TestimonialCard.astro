---
interface Props {
  quote: string;
  name: string;
  role: string;
  company: string;
}

const { quote, name, role, company } = Astro.props;
---

<blockquote class="flex flex-col justify-between rounded-lg border border-neutral-200 bg-white p-6 shadow-xs">
  <p class="text-sm leading-relaxed text-neutral-700">
    &ldquo;{quote}&rdquo;
  </p>
  <footer class="mt-4 border-t border-neutral-100 pt-4">
    <p class="text-sm font-semibold text-neutral-900">{name}</p>
    <p class="text-xs text-neutral-500">
      {role}, {company}
    </p>
  </footer>
</blockquote>
