---
import SectionHeading from '@components/shared/SectionHeading.astro';
import PricingTierComponent from './PricingTier.astro';
import { pricingTiers } from '@data/pricing';
---

<section class="bg-white py-16 sm:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <SectionHeading
      overline="Pricing"
      title="Simple, transparent pricing"
      subtitle="Start free. Scale as your integration needs grow. No hidden fees."
    />

    <div class="mx-auto grid max-w-5xl gap-6 lg:grid-cols-3">
      {pricingTiers.map((tier) => (
        <PricingTierComponent tier={tier} />
      ))}
    </div>
  </div>
</section>
