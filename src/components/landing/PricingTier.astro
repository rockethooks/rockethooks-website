---
import { Icon } from 'astro-icon/components';
import type { PricingTier } from '@data/types';

interface Props {
  tier: PricingTier;
}

const { tier } = Astro.props;
---

<div
  class:list={[
    'relative flex flex-col rounded-lg border p-6 shadow-xs',
    tier.highlighted
      ? 'border-brand-600 ring-1 ring-brand-600'
      : 'border-neutral-200 bg-white',
  ]}
>
  {tier.badge && (
    <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-brand-600 px-3 py-0.5 text-xs font-semibold text-white">
      {tier.badge}
    </span>
  )}

  <div class="mb-6">
    <h3 class="text-lg font-semibold text-neutral-900">{tier.name}</h3>
    <div class="mt-2 flex items-baseline gap-1">
      <span class="text-4xl font-semibold tracking-tight text-neutral-900">
        {tier.price}
      </span>
      {tier.priceNote && (
        <span class="text-sm text-neutral-500">{tier.priceNote}</span>
      )}
    </div>
    <p class="mt-3 text-sm text-neutral-600">{tier.description}</p>
  </div>

  <ul class="mb-8 flex-1 space-y-3">
    {tier.features.map((feature: string) => (
      <li class="flex items-start gap-2.5 text-sm text-neutral-700">
        <Icon name="lucide:check" size={16} class="mt-0.5 shrink-0 text-brand-600" />
        <span>{feature}</span>
      </li>
    ))}
  </ul>

  <a
    href={tier.cta.href}
    class:list={[
      'block rounded-lg py-2.5 text-center text-sm font-semibold transition-colors',
      tier.highlighted
        ? 'bg-brand-600 text-white shadow-xs hover:bg-brand-700'
        : 'border border-neutral-300 bg-white text-neutral-700 hover:bg-neutral-50',
    ]}
  >
    {tier.cta.label}
  </a>
</div>
