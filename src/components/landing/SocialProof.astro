---
const stats = [
  { value: '10,000+', label: 'API monitors active' },
  { value: '99.9%', label: 'uptime SLA' },
  { value: '<2s', label: 'avg. webhook delivery' },
  { value: '60-80%', label: 'cost reduction' },
];
---

<section class="border-y border-neutral-200 bg-neutral-50">
  <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 gap-6 sm:gap-8 lg:grid-cols-4">
      {stats.map((stat) => (
        <div class="text-center">
          <p class="text-2xl font-semibold text-brand-600 sm:text-3xl">{stat.value}</p>
          <p class="mt-1 text-sm text-neutral-600">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
