---
import { Schema } from 'astro-seo-schema';

interface Props {
  title: string;
  description: string;
  publishDate: Date;
  updatedDate?: Date;
  authorName: string;
  authorUrl?: string;
  image?: string;
  keywords?: string[];
  url: string;
}

const { title, description, publishDate, updatedDate, authorName, authorUrl, image, keywords, url } =
  Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://rockethooks.com';
const fullUrl = url.startsWith('http') ? url : `${siteUrl}${url}`;
const imageUrl = image?.startsWith('http') ? image : image ? `${siteUrl}${image}` : undefined;
---

<Schema
  item={{
    '@context': 'https://schema.org' as const,
    '@type': 'TechArticle',
    headline: title,
    description,
    datePublished: publishDate.toISOString(),
    ...(updatedDate ? { dateModified: updatedDate.toISOString() } : {}),
    author: {
      '@type': 'Person' as const,
      name: authorName,
      ...(authorUrl ? { url: authorUrl } : {}),
    },
    publisher: {
      '@type': 'Organization' as const,
      name: 'RocketHooks',
      url: siteUrl,
      logo: {
        '@type': 'ImageObject' as const,
        url: `${siteUrl}/logo.svg`,
        width: '600px',
        height: '60px',
      },
    },
    mainEntityOfPage: {
      '@type': 'WebPage' as const,
      '@id': fullUrl,
    },
    ...(imageUrl ? { image: imageUrl } : {}),
    ...(keywords?.length ? { keywords: keywords.join(', ') } : {}),
  }}
/>
