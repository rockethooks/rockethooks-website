---
import { Schema } from 'astro-seo-schema';

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://www.rockethooks.com';
---

<Schema
  item={{
    '@context': 'https://schema.org' as const,
    '@type': 'WebSite',
    name: 'RocketHooks',
    alternateName: 'RocketHooks API Platform',
    url: siteUrl,
    description:
      'API transformation platform that converts API endpoints into real-time event streams via intelligent polling, change detection, and reliable webhook delivery.',
  }}
/>
