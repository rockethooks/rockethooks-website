---
import { Schema } from 'astro-seo-schema';

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://www.rockethooks.com';
---

<Schema
  item={{
    '@context': 'https://schema.org' as const,
    '@type': 'WebSite',
    name: 'RocketHooks',
    url: siteUrl,
    description:
      'API transformation platform that converts REST API endpoints into real-time event streams via intelligent polling, change detection, and multi-channel notifications.',
    potentialAction: {
      '@type': 'SearchAction' as const,
      target: {
        '@type': 'EntryPoint' as const,
        urlTemplate: `${siteUrl}/search?q={search_term_string}`,
      },
      'query-input': 'required name=search_term_string',
    },
  }}
/>
