---
import { Schema } from 'astro-seo-schema';

interface Props {
  name: string;
  description: string;
  price: string;
  priceCurrency?: string;
  url?: string;
}

const { name, description, price, priceCurrency = 'USD', url } = Astro.props;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://rockethooks.com';
---

<Schema
  item={{
    '@context': 'https://schema.org' as const,
    '@type': 'Offer',
    name,
    description,
    price,
    priceCurrency,
    url: url ? (url.startsWith('http') ? url : `${siteUrl}${url}`) : `${siteUrl}/pricing`,
    seller: {
      '@type': 'Organization' as const,
      name: 'RocketHooks',
    },
  }}
/>
