---
import { Schema } from 'astro-seo-schema';

interface Props {
  name: string;
  description: string;
}

const { name, description } = Astro.props;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://rockethooks.com';
const pageUrl = `${siteUrl}${Astro.url.pathname}`;
---

<Schema
  item={{
    '@context': 'https://schema.org' as const,
    '@type': 'CollectionPage',
    name,
    description,
    url: pageUrl,
    isPartOf: {
      '@type': 'WebSite' as const,
      name: 'RocketHooks',
      url: siteUrl,
    },
  }}
/>
