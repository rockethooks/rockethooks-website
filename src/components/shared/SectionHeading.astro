---
interface Props {
  overline?: string;
  title: string;
  subtitle?: string;
  centered?: boolean;
}

const { overline, title, subtitle, centered = true } = Astro.props;
---

<div class:list={['mb-12 max-w-3xl', centered && 'mx-auto text-center']}>
  {overline && (
    <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-brand-600">
      {overline}
    </p>
  )}
  <h2 class="text-3xl font-semibold tracking-tight text-neutral-900 sm:text-4xl">
    {title}
  </h2>
  {subtitle && (
    <p class="mt-4 text-lg leading-relaxed text-neutral-600">
      {subtitle}
    </p>
  )}
</div>
