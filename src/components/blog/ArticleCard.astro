---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, author, category, image } = post.data;

const truncatedDescription =
  description.length > 120 ? `${description.slice(0, 117)}...` : description;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});

const categoryColors: Record<string, { bg: string; text: string }> = {
  educational: { bg: 'bg-brand-50', text: 'text-brand-700' },
  'problem-aware': { bg: 'bg-accent-50', text: 'text-accent-700' },
  comparison: { bg: 'bg-success-light', text: 'text-success-dark' },
};

const categoryStyle = categoryColors[category] ?? categoryColors.educational;

const categoryLabels: Record<string, string> = {
  educational: 'Educational',
  'problem-aware': 'Problem-Aware',
  comparison: 'Comparison',
};
---

<article class="group flex flex-col overflow-hidden rounded-lg border border-neutral-200 bg-white shadow-xs transition-all hover:border-brand-200 hover:shadow-sm">
  <a href={`/blog/${post.id}`} class="flex flex-1 flex-col">
    {/* Image / Gradient fallback */}
    <div class="relative aspect-[16/9] overflow-hidden">
      {image ? (
        <img
          src={image.src}
          alt={image.alt}
          width={640}
          height={360}
          loading="lazy"
          class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
        />
      ) : (
        <div class="h-full w-full bg-gradient-to-br from-brand-100 via-brand-50 to-accent-50" />
      )}
      <span
        class:list={[
          'absolute top-3 left-3 rounded-full px-2.5 py-0.5 text-xs font-semibold',
          categoryStyle.bg,
          categoryStyle.text,
        ]}
      >
        {categoryLabels[category]}
      </span>
    </div>

    {/* Content */}
    <div class="flex flex-1 flex-col p-5">
      <h3 class="text-lg font-semibold leading-snug text-neutral-900 group-hover:text-brand-700">
        {title}
      </h3>
      <p class="mt-2 flex-1 text-sm leading-relaxed text-neutral-600">
        {truncatedDescription}
      </p>

      {/* Meta: author + date */}
      <div class="mt-4 flex items-center gap-3 border-t border-neutral-100 pt-3 text-xs text-neutral-500">
        <span class="font-medium text-neutral-700">{author}</span>
        <span aria-hidden="true">--</span>
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
      </div>
    </div>
  </a>
</article>
