---
import BaseLayout from './BaseLayout.astro';
import Header from '@components/shared/Header';
import Footer from '@components/shared/Footer';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: { src: string; alt: string };
  noindex?: boolean;
  alternates?: Array<{ hreflang: string; href: string }>;
}

const props = Astro.props;
---

<BaseLayout
  title={props.title}
  description={props.description}
  canonical={props.canonical}
  image={props.image}
  noindex={props.noindex}
  alternates={props.alternates}
>
  <slot name="head" slot="head" />
  <Header client:idle pathname={Astro.url.pathname} slot="header" />
  <slot />
  <Footer slot="footer" />

  <script>
    import { animate, inView, stagger } from "motion";

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (prefersReducedMotion) {
      // Skip all animations but keep content visible
      document.querySelectorAll('.animate-section').forEach((el) => {
        (el as HTMLElement).style.opacity = '1';
      });
    } else {
      // Section and card entrance animations
      inView(".animate-section", (el) => {
        animate(
          el as Element,
          { opacity: [0, 1], y: [30, 0] } as Record<string, [number, number]>,
          { duration: 0.6, ease: [0.39, 0.24, 0.3, 1] }
        );
        const cards = el.querySelectorAll(".animate-card");
        if (cards.length) {
          animate(
            Array.from(cards) as Element[],
            { opacity: [0, 1], y: [20, 0] } as Record<string, [number, number]>,
            { delay: stagger(0.15), ease: [0.39, 0.24, 0.3, 1] }
          );
        }
      }, { amount: 0.2 });

      // Counter animation
      document.querySelectorAll('.animate-counter').forEach((el) => {
        inView(el, () => {
          const target = parseFloat(el.getAttribute('data-count-target') || '0');
          const prefix = el.getAttribute('data-count-prefix') || '';
          const suffix = el.getAttribute('data-count-suffix') || '';
          const decimals = parseInt(el.getAttribute('data-count-decimals') || '0', 10);

          animate(0, target, {
            duration: 1.5,
            ease: [0.22, 1, 0.36, 1],
            onUpdate: (value: number) => {
              (el as HTMLElement).textContent = `${prefix}${decimals > 0 ? value.toFixed(decimals) : Math.round(value).toLocaleString()}${suffix}`;
            },
          });
        }, { amount: 0.5 });
      });
    }
  </script>
</BaseLayout>
