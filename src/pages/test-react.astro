---
import { Button } from '@components/ui/button';
import { cn } from '@lib/utils';

// Verify cn() utility works at build time
const testClass = cn('text-sm', 'font-medium', 'text-brand-600');
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>React Integration Test</title>
  </head>
  <body class="p-8">
    <h1 class="text-2xl font-semibold mb-6">React + shadcn/ui Integration Test</h1>

    <section class="space-y-4">
      <h2 class="text-lg font-medium">Button Variants</h2>

      <div class="flex flex-wrap gap-3">
        <Button client:load>Default Button</Button>
        <Button client:load variant="outline">Outline Button</Button>
        <Button client:load variant="secondary">Secondary Button</Button>
        <Button client:load variant="ghost">Ghost Button</Button>
        <Button client:load variant="destructive">Destructive Button</Button>
        <Button client:load variant="link">Link Button</Button>
      </div>

      <div class="flex flex-wrap gap-3">
        <Button client:load size="xs">XS Size</Button>
        <Button client:load size="sm">SM Size</Button>
        <Button client:load>Default Size</Button>
        <Button client:load size="lg">LG Size</Button>
      </div>
    </section>

    <section class="mt-8">
      <h2 class="text-lg font-medium mb-2">cn() Utility Test</h2>
      <p class={testClass}>
        This text uses cn() utility — class: {testClass}
      </p>
    </section>

    <section class="mt-8">
      <h2 class="text-lg font-medium mb-2">Static Render (no client directive)</h2>
      <Button>Static Button (SSR only)</Button>
    </section>
  </body>
</html>
