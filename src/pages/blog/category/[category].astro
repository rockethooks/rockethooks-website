---
import BlogLayout from '@layouts/BlogLayout.astro';
import { ArticleList } from '@components/blog/ArticleList';
import { getPostsByCategory } from '@utils/content';
import type { ArticleCardProps } from '@components/blog/ArticleCard';

type Category = 'educational' | 'problem-aware' | 'comparison';

export function getStaticPaths() {
  const categories: Category[] = ['educational', 'problem-aware', 'comparison'];
  return categories.map((category) => ({
    params: { category },
  }));
}

const { category } = Astro.params as { category: Category };

const categoryLabels: Record<Category, string> = {
  educational: 'Educational',
  'problem-aware': 'Problem-Aware',
  comparison: 'Comparison',
};

const posts = await getPostsByCategory(category);
const label = categoryLabels[category];

// Serialize collection entries to plain props for React component
const postProps: ArticleCardProps[] = posts.map((post) => ({
  title: post.data.title,
  description: post.data.description,
  pubDate: post.data.pubDate.toISOString(),
  author: post.data.author,
  category: post.data.category,
  image: post.data.image,
  slug: post.id,
}));
---

<BlogLayout
  title={`${label} Articles`}
  description={`Browse ${label.toLowerCase()} articles about API transformation, webhook integration, and real-time event streaming.`}
  currentCategory={category}
>
  <ArticleList posts={postProps} />
</BlogLayout>
