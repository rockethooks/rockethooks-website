---
import BlogLayout from '@layouts/BlogLayout.astro';
import { ArticleList } from '@components/blog/ArticleList';
import CollectionPageSchema from '@components/seo/CollectionPageSchema.astro';
import { getPublishedPosts } from '@utils/content';
import type { ArticleCardProps } from '@components/blog/ArticleCard';

const posts = await getPublishedPosts();

// Serialize collection entries to plain props for React component
const postProps: ArticleCardProps[] = posts.map((post) => ({
  title: post.data.title,
  description: post.data.description,
  pubDate: post.data.pubDate.toISOString(),
  author: post.data.author,
  category: post.data.category,
  image: post.data.image,
  slug: post.id,
}));
---

<BlogLayout>
  <Fragment slot="head">
    <CollectionPageSchema
      name="RocketHooks Blog"
      description="Insights, tutorials, and guides on API transformation, webhook integration, and real-time event streaming."
    />
  </Fragment>
  <ArticleList posts={postProps} />
</BlogLayout>
