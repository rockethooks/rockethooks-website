---
import { getCollection, render } from 'astro:content';
import BlogPostLayout from '@layouts/BlogPostLayout.astro';
import ArticleSchema from '@components/seo/ArticleSchema.astro';
import PersonSchema from '@components/seo/PersonSchema.astro';
import { TableOfContents } from '@components/blog/TableOfContents';
import { AuthorBio } from '@components/blog/AuthorBio';
import { RelatedArticles } from '@components/blog/RelatedArticles';
import { NewsletterSignup } from '@components/blog/NewsletterSignup';
import { getAuthorById, getRelatedArticles } from '@utils/content';
import type { ArticleCardProps } from '@components/blog/ArticleCard';
import type { AuthorProps } from '../../types/content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings, remarkPluginFrontmatter } = await render(post);

const authorEntry = await getAuthorById(post.data.author);
const author = authorEntry
  ? { id: authorEntry.id, ...authorEntry.data }
  : { id: post.data.author, name: post.data.author };

const relatedArticles = await getRelatedArticles(post.id, post.data.category);
const readingTime = remarkPluginFrontmatter?.readingTime as string | undefined;

const authorUrl = author.linkedin ?? author.github;

// Serialize author for React component
const authorProps: AuthorProps = {
  name: author.name,
  title: author.title,
  bio: author.bio,
  avatar: author.avatar,
  linkedin: author.linkedin,
  github: author.github,
  twitter: author.twitter,
};

// Serialize related articles for React component
const relatedArticleProps: ArticleCardProps[] = relatedArticles.map((article) => ({
  title: article.data.title,
  description: article.data.description,
  pubDate: article.data.pubDate.toISOString(),
  author: article.data.author,
  category: article.data.category,
  image: article.data.image,
  slug: article.id,
}));

// Serialize headings for React component
const tocHeadings = headings.map((h) => ({
  depth: h.depth,
  slug: h.slug,
  text: h.text,
}));
---

<BlogPostLayout
  title={post.data.title}
  description={post.data.description}
  publishDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  author={author}
  image={post.data.image}
  category={post.data.category}
  tags={post.data.tags}
  readingTime={readingTime}
>
  <Fragment slot="head">
    <ArticleSchema
      title={post.data.title}
      description={post.data.description}
      publishDate={post.data.pubDate}
      updatedDate={post.data.updatedDate}
      authorName={author.name}
      authorUrl={authorUrl}
      image={post.data.image?.src}
      keywords={post.data.seoKeywords}
      url={`/blog/${post.id}`}
    />
    <PersonSchema
      name={author.name}
      jobTitle={author.title}
      description={author.bio}
      image={author.avatar}
      linkedin={author.linkedin}
      github={author.github}
      twitter={author.twitter}
    />
  </Fragment>

  <TableOfContents slot="toc" headings={tocHeadings} client:idle />

  <Content />

  <AuthorBio slot="authorBio" author={authorProps} />

  <RelatedArticles slot="relatedArticles" articles={relatedArticleProps} />

  <div slot="newsletter">
    <NewsletterSignup />
  </div>
</BlogPostLayout>
