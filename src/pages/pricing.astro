---
import LandingLayout from '@layouts/LandingLayout.astro';
import { SectionHeading } from '@components/shared/SectionHeading';
import { PricingTier } from '@components/landing/PricingTier';
import { FinalCTA } from '@components/shared/FinalCTA';
import WebApplicationSchema from '@components/seo/WebApplicationSchema.astro';
import OfferSchema from '@components/seo/OfferSchema.astro';
import FAQSchema from '@components/seo/FAQSchema.astro';
import BreadcrumbSchema from '@components/seo/BreadcrumbSchema.astro';
import { Breadcrumbs } from '@components/shared/Breadcrumbs';
import { getBreadcrumbs } from '@utils/content';
import { Icon } from 'astro-icon/components';
import { pricingTiers } from '@data/pricing';
import { faqs } from '@data/faqs';

const breadcrumbItems = getBreadcrumbs(Astro.url.pathname);
const pricingFaqs = faqs.filter((faq) => faq.category === 'pricing');

const additionalPricingFaqs = [
  {
    question: 'What payment methods do you accept?',
    answer:
      'We accept all major credit cards (Visa, Mastercard, American Express) and process payments securely through Stripe. Enterprise customers can pay by invoice with NET-30 terms.',
  },
  {
    question: 'Can I get a refund?',
    answer:
      'We offer a 30-day money-back guarantee on all paid plans. If you are not satisfied, contact support within 30 days of your purchase for a full refund -- no questions asked.',
  },
  {
    question: 'What counts as a webhook delivery?',
    answer:
      'A webhook delivery is counted each time RocketHooks sends a payload to one of your configured webhook destination URLs. Each destination counts as one delivery per event.',
  },
  {
    question: 'What happens to my data if I downgrade?',
    answer:
      'Your endpoints and configurations are preserved when you downgrade. Endpoints exceeding the lower plan limit are paused (not deleted) and can be reactivated when you upgrade again. Historical data is retained according to your plan log retention period.',
  },
];

const allPricingFaqs = [
  ...pricingFaqs,
  ...additionalPricingFaqs.map((faq) => ({
    ...faq,
    category: 'pricing' as const,
  })),
];

interface ComparisonFeature {
  name: string;
  developer: string | boolean;
  startup: string | boolean;
  growth: string | boolean;
  enterprise: string | boolean;
  comingSoon?: boolean;
}

const comparisonFeatures: ComparisonFeature[] = [
  { name: 'API endpoints', developer: '6', startup: '15', growth: '50', enterprise: 'Unlimited' },
  { name: 'Webhook destinations', developer: '1', startup: '5', growth: '20', enterprise: 'Unlimited' },
  { name: 'Email notifications', developer: true, startup: true, growth: true, enterprise: true, comingSoon: true },
  { name: 'Slack integration', developer: '1 workspace', startup: '3 workspaces', growth: 'Unlimited', enterprise: 'Full enterprise', comingSoon: true },
  { name: 'n8n workflows', developer: '1', startup: 'Unlimited', growth: 'Unlimited', enterprise: 'Unlimited', comingSoon: true },
  { name: 'Zapier Zaps', developer: false, startup: '5', growth: 'Unlimited', enterprise: 'Unlimited', comingSoon: true },
  { name: 'Make.com scenarios', developer: false, startup: '5', growth: 'Unlimited', enterprise: 'Unlimited', comingSoon: true },
  { name: 'Polling interval', developer: '30s - 24h', startup: '30s - 24h', growth: '30s - 24h', enterprise: '30s - 24h' },
  { name: 'JSONPath field monitoring', developer: true, startup: true, growth: true, enterprise: true },
  { name: 'Deep-diff change detection', developer: true, startup: true, growth: true, enterprise: true },
  { name: 'HMAC-SHA256 signed webhooks', developer: true, startup: true, growth: true, enterprise: true },
  { name: 'Visual response diff viewer', developer: true, startup: true, growth: true, enterprise: true },
  { name: 'Test connection & validation', developer: true, startup: true, growth: true, enterprise: true },
  { name: 'Clone endpoints', developer: true, startup: true, growth: true, enterprise: true },
  { name: 'Retry with exponential backoff', developer: true, startup: true, growth: true, enterprise: true },
  { name: 'Dead letter queue', developer: true, startup: true, growth: true, enterprise: true },
  { name: 'Log retention', developer: '7 days', startup: '30 days', growth: '90 days', enterprise: 'Custom' },
  { name: 'Team members', developer: 'Solo', startup: '3', growth: '10', enterprise: 'Unlimited' },
  { name: 'RBAC', developer: false, startup: false, growth: true, enterprise: true, comingSoon: true },
  { name: 'Pattern matching', developer: false, startup: false, growth: true, enterprise: true, comingSoon: true },
  { name: 'Threshold detection', developer: false, startup: false, growth: true, enterprise: true, comingSoon: true },
  { name: 'Audit logs', developer: false, startup: false, growth: true, enterprise: true, comingSoon: true },
  { name: 'SSO/SAML', developer: false, startup: false, growth: false, enterprise: true, comingSoon: true },
  { name: 'Two-tier circuit breaker', developer: true, startup: true, growth: true, enterprise: true },
  { name: 'Uptime SLA', developer: '99.9%', startup: '99.9%', growth: '99.95%', enterprise: '99.99%' },
  { name: 'Support', developer: 'Email (<48h)', startup: 'Slack (<24h)', growth: 'Phone', enterprise: '24/7 (<1h)' },
];
---

<LandingLayout
  title="Pricing"
  description="Simple, transparent pricing for RocketHooks. Start with a 14-day free trial on any plan. Developer $49/month, Startup $149/month, Growth $499/month, or Enterprise custom pricing."
  canonical="/pricing"
>
  <Fragment slot="head">
    <WebApplicationSchema />
    <OfferSchema
      name="RocketHooks Developer"
      description="6 API endpoints, 1 webhook destination, 7-day logs, email support. $49/month."
      price="49"
    />
    <OfferSchema
      name="RocketHooks Startup"
      description="15 API endpoints, 5 webhook destinations, 30-day logs, Slack support. $149/month."
      price="149"
    />
    <OfferSchema
      name="RocketHooks Growth"
      description="50 API endpoints, 20 webhook destinations, 90-day logs, phone support. $499/month."
      price="499"
    />
    <OfferSchema
      name="RocketHooks Enterprise"
      description="Unlimited endpoints, unlimited destinations, custom log retention, 24/7 dedicated support."
      price="0"
      url="/contact?subject=enterprise"
    />
    <FAQSchema items={allPricingFaqs.map((faq) => ({ question: faq.question, answer: faq.answer }))} />
    <BreadcrumbSchema items={breadcrumbItems.slice(1).map((item) => ({ name: item.label, href: item.href }))} />
  </Fragment>

  <!-- Pricing header + tiers -->
  <section class="bg-white py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={breadcrumbItems} />

      <SectionHeading
        overline="Pricing"
        title="Simple, transparent pricing"
        subtitle="Start with a 14-day free trial on any plan. No credit card required. Scale as your integration needs grow."
      />

      <div class="mx-auto grid max-w-6xl gap-6 lg:grid-cols-4">
        {pricingTiers.map((tier) => (
          <PricingTier tier={tier} />
        ))}
      </div>

      <p class="mx-auto mt-8 max-w-2xl text-center text-sm text-neutral-500">
        All plans include HMAC-SHA256 signed webhooks, exponential backoff retries, dead letter queue, and KMS-encrypted credentials. 14-day free trial on all plans.
      </p>
    </div>
  </section>

  <!-- Feature comparison matrix -->
  <section class="bg-neutral-50 py-16 sm:py-24">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <SectionHeading
        overline="Compare plans"
        title="Feature comparison"
        subtitle="See exactly what you get with each plan. Every feature, every limit, side by side."
      />

      <!-- Desktop table -->
      <div class="hidden sm:block overflow-x-auto rounded-lg border border-neutral-200 bg-white shadow-xs">
        <table class="w-full text-left text-sm">
          <thead>
            <tr class="border-b border-neutral-200 bg-neutral-50">
              <th class="px-6 py-4 font-semibold text-neutral-900" scope="col">Feature</th>
              <th class="px-4 py-4 text-center font-semibold text-neutral-900" scope="col">Developer</th>
              <th class="px-4 py-4 text-center font-semibold text-brand-600" scope="col">Startup</th>
              <th class="px-4 py-4 text-center font-semibold text-neutral-900" scope="col">Growth</th>
              <th class="px-4 py-4 text-center font-semibold text-neutral-900" scope="col">Enterprise</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-neutral-100">
            {comparisonFeatures.map((feature) => (
              <tr>
                <td class="px-6 py-3.5 text-neutral-700">
                  {feature.name}
                  {feature.comingSoon && (
                    <span class="ml-1.5 inline-block rounded bg-amber-100 px-1.5 py-0.5 text-xs font-medium text-amber-700">Coming Soon</span>
                  )}
                </td>
                <td class="px-4 py-3.5 text-center text-neutral-600">
                  {typeof feature.developer === 'boolean' ? (
                    feature.developer ? (
                      <Icon name="lucide:check" size={18} class="inline-block text-brand-600" aria-label="Included" />
                    ) : (
                      <Icon name="lucide:minus" size={18} class="inline-block text-neutral-300" aria-label="Not included" />
                    )
                  ) : (
                    feature.developer
                  )}
                </td>
                <td class="px-4 py-3.5 text-center text-neutral-600 bg-brand-50/30">
                  {typeof feature.startup === 'boolean' ? (
                    feature.startup ? (
                      <Icon name="lucide:check" size={18} class="inline-block text-brand-600" aria-label="Included" />
                    ) : (
                      <Icon name="lucide:minus" size={18} class="inline-block text-neutral-300" aria-label="Not included" />
                    )
                  ) : (
                    feature.startup
                  )}
                </td>
                <td class="px-4 py-3.5 text-center text-neutral-600">
                  {typeof feature.growth === 'boolean' ? (
                    feature.growth ? (
                      <Icon name="lucide:check" size={18} class="inline-block text-brand-600" aria-label="Included" />
                    ) : (
                      <Icon name="lucide:minus" size={18} class="inline-block text-neutral-300" aria-label="Not included" />
                    )
                  ) : (
                    feature.growth
                  )}
                </td>
                <td class="px-4 py-3.5 text-center text-neutral-600">
                  {typeof feature.enterprise === 'boolean' ? (
                    feature.enterprise ? (
                      <Icon name="lucide:check" size={18} class="inline-block text-brand-600" aria-label="Included" />
                    ) : (
                      <Icon name="lucide:minus" size={18} class="inline-block text-neutral-300" aria-label="Not included" />
                    )
                  ) : (
                    feature.enterprise
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- Mobile comparison cards -->
      <div class="sm:hidden space-y-6">
        {pricingTiers.map((tier) => (
          <div class:list={[
            'rounded-lg border p-5',
            tier.highlighted ? 'border-brand-600 ring-1 ring-brand-600' : 'border-neutral-200 bg-white',
          ]}>
            <h3 class="text-lg font-semibold text-neutral-900">{tier.name}</h3>
            <div class="mt-1 flex items-baseline gap-1">
              <span class="text-2xl font-semibold text-neutral-900">{tier.price}</span>
              {tier.priceNote && <span class="text-sm text-neutral-500">{tier.priceNote}</span>}
            </div>
            <dl class="mt-4 space-y-2.5">
              {comparisonFeatures.map((feature) => {
                const tierKey = tier.name.toLowerCase() as 'developer' | 'startup' | 'growth' | 'enterprise';
                const value = feature[tierKey];
                return (
                  <div class="flex items-center justify-between text-sm">
                    <dt class="text-neutral-600">
                      {feature.name}
                      {feature.comingSoon && (
                        <span class="ml-1 inline-block rounded bg-amber-100 px-1 py-0.5 text-xs font-medium text-amber-700">Soon</span>
                      )}
                    </dt>
                    <dd class="font-medium text-neutral-900">
                      {typeof value === 'boolean' ? (
                        value ? (
                          <Icon name="lucide:check" size={16} class="text-brand-600" aria-label="Included" />
                        ) : (
                          <Icon name="lucide:minus" size={16} class="text-neutral-300" aria-label="Not included" />
                        )
                      ) : (
                        value
                      )}
                    </dd>
                  </div>
                );
              })}
            </dl>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ section -->
  <section class="bg-white py-16 sm:py-24">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <SectionHeading
        overline="FAQ"
        title="Pricing questions, answered"
        subtitle="Everything you need to know about RocketHooks pricing and billing."
      />

      <dl class="space-y-4">
        {allPricingFaqs.map((faq) => (
          <details class="group rounded-lg border border-neutral-200 bg-neutral-50">
            <summary class="flex cursor-pointer items-center justify-between px-5 py-4 text-left text-sm font-semibold text-neutral-900 [&::-webkit-details-marker]:hidden">
              {faq.question}
              <span class="ml-4 shrink-0 text-neutral-400 transition-transform group-open:rotate-45">
                +
              </span>
            </summary>
            <dd class="border-t border-neutral-100 px-5 py-4 text-sm leading-relaxed text-neutral-600">
              {faq.answer}
            </dd>
          </details>
        ))}
      </dl>
    </div>
  </section>

  <FinalCTA
    headline="Start monitoring APIs in minutes"
    subtitle="Try RocketHooks free for 14 days. No credit card required. Developer plan starts at $49/month."
  />
</LandingLayout>
