---
import LandingLayout from '@layouts/LandingLayout.astro';
import BreadcrumbSchema from '@components/seo/BreadcrumbSchema.astro';
import { Breadcrumbs } from '@components/shared/Breadcrumbs';
import { Icon } from 'astro-icon/components';
import { getBreadcrumbs } from '@utils/content';
import { ContactForm } from '@components/forms/ContactForm';
import { Toaster } from '@components/ui/sonner';

const breadcrumbItems = getBreadcrumbs(Astro.url.pathname);
---

<LandingLayout
  title="Contact Us"
  description="Get in touch with the RocketHooks team. Questions about API transformation, pricing, or enterprise plans -- we are here to help."
>
  <Fragment slot="head">
    <BreadcrumbSchema items={breadcrumbItems.slice(1).map((item) => ({ name: item.label, href: item.href }))} />
  </Fragment>

  <section class="bg-neutral-50 py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={breadcrumbItems} />
      <h1 class="text-4xl font-semibold tracking-tight text-neutral-900 sm:text-5xl">
        Get in Touch
      </h1>
      <p class="mt-4 text-lg leading-relaxed text-neutral-600">
        Have a question about RocketHooks? Want to discuss an enterprise plan?
        We would love to hear from you.
      </p>
    </div>
  </section>

  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-5">
        <!-- Contact Form -->
        <div class="lg:col-span-3">
          <h2 class="text-2xl font-semibold text-neutral-900">Send Us a Message</h2>
          <p class="mt-2 text-sm text-neutral-600">
            Fill out the form below and we will get back to you within one business day.
          </p>

          <ContactForm client:load />
        </div>

        <!-- Alternative Contact -->
        <div class="lg:col-span-2">
          <h2 class="text-2xl font-semibold text-neutral-900">Other Ways to Reach Us</h2>

          <div class="mt-8 space-y-6">
            <div class="flex gap-4">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-brand-100">
                <Icon name="lucide:mail" size={20} class="text-brand-700" />
              </div>
              <div>
                <h3 class="text-sm font-semibold text-neutral-900">Email</h3>
                <a
                  href="mailto:hello@rockethooks.com"
                  class="text-sm text-brand-600 transition-colors hover:text-brand-700"
                >
                  hello@rockethooks.com
                </a>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-brand-100">
                <Icon name="lucide:message-circle" size={20} class="text-brand-700" />
              </div>
              <div>
                <h3 class="text-sm font-semibold text-neutral-900">Community</h3>
                <p class="text-sm text-neutral-600">
                  Join our
                  <a
                    href="https://github.com/rockethooks"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-brand-600 transition-colors hover:text-brand-700"
                  >
                    GitHub community
                  </a>
                  for discussions and support.
                </p>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-brand-100">
                <Icon name="lucide:headset" size={20} class="text-brand-700" />
              </div>
              <div>
                <h3 class="text-sm font-semibold text-neutral-900">Enterprise Support</h3>
                <p class="text-sm text-neutral-600">
                  Need dedicated support or custom SLAs? Reach out at
                  <a
                    href="mailto:enterprise@rockethooks.com"
                    class="text-brand-600 transition-colors hover:text-brand-700"
                  >
                    enterprise@rockethooks.com
                  </a>
                </p>
              </div>
            </div>
          </div>

          <!-- Social Links -->
          <div class="mt-10 border-t border-neutral-200 pt-8">
            <h3 class="text-sm font-semibold text-neutral-900">Follow Us</h3>
            <div class="mt-4 flex gap-4">
              <a
                href="https://github.com/rockethooks"
                target="_blank"
                rel="noopener noreferrer"
                class="flex h-10 w-10 items-center justify-center rounded-lg border border-neutral-200 text-neutral-500 transition-colors hover:border-neutral-300 hover:text-neutral-700"
                aria-label="GitHub"
              >
                <Icon name="lucide:github" size={20} />
              </a>
              <a
                href="https://linkedin.com/company/rockethooks"
                target="_blank"
                rel="noopener noreferrer"
                class="flex h-10 w-10 items-center justify-center rounded-lg border border-neutral-200 text-neutral-500 transition-colors hover:border-neutral-300 hover:text-neutral-700"
                aria-label="LinkedIn"
              >
                <Icon name="lucide:linkedin" size={20} />
              </a>
              <a
                href="https://twitter.com/rockethooks"
                target="_blank"
                rel="noopener noreferrer"
                class="flex h-10 w-10 items-center justify-center rounded-lg border border-neutral-200 text-neutral-500 transition-colors hover:border-neutral-300 hover:text-neutral-700"
                aria-label="Twitter"
              >
                <Icon name="lucide:twitter" size={20} />
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Toaster client:load />
</LandingLayout>
