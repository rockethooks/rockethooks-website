---
import LandingLayout from '@layouts/LandingLayout.astro';
import OrganizationSchema from '@components/seo/OrganizationSchema.astro';
import WebSiteSchema from '@components/seo/WebSiteSchema.astro';
import Hero from '@components/landing/Hero.astro';
import SocialProof from '@components/landing/SocialProof.astro';
import HowItWorks from '@components/landing/HowItWorks.astro';
import Features from '@components/landing/Features.astro';
import UseCases from '@components/landing/UseCases.astro';
import Testimonials from '@components/landing/Testimonials.astro';
import PricingPreview from '@components/landing/PricingPreview.astro';
import FAQ from '@components/landing/FAQ.astro';
import FinalCTA from '@components/shared/FinalCTA.astro';
---

<LandingLayout
  description="Transform REST API endpoints into real-time event streams with intelligent polling, change detection, and multi-channel notifications. No infrastructure changes required."
>
  <Fragment slot="head">
    <OrganizationSchema />
    <WebSiteSchema />
  </Fragment>

  <Hero />
  <SocialProof />
  <HowItWorks />
  <Features />
  <UseCases />
  <Testimonials />
  <PricingPreview />
  <FAQ />
  <FinalCTA />
</LandingLayout>
