---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/shared/Header.astro';
import Footer from '@components/shared/Footer.astro';
import OrganizationSchema from '@components/seo/OrganizationSchema.astro';
---

<BaseLayout
  description="Transform REST API endpoints into real-time event streams with intelligent polling, change detection, and multi-channel notifications. No infrastructure changes required."
>
  <OrganizationSchema slot="head" />
  <Header slot="header" />

  <section class="relative overflow-hidden bg-white">
    <div class="mx-auto max-w-7xl px-4 py-24 sm:px-6 sm:py-32 lg:px-8 lg:py-40">
      <div class="mx-auto max-w-3xl text-center">
        <h1 class="text-4xl font-semibold tracking-tight text-neutral-900 sm:text-5xl lg:text-6xl">
          Turn Any REST API Into
          <span class="text-brand-600">Real-Time Events</span>
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-neutral-600 sm:text-xl">
          Intelligent polling, change detection, and multi-channel notifications -- without touching your existing infrastructure.
        </p>
        <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a
            href="https://app.rockethooks.com/signup"
            class="inline-flex items-center rounded-lg bg-brand-600 px-6 py-3 text-base font-semibold text-white shadow-xs transition-colors hover:bg-brand-700"
          >
            Start Free Trial
          </a>
          <a
            href="/use-cases"
            class="inline-flex items-center rounded-lg border border-neutral-300 bg-white px-6 py-3 text-base font-semibold text-neutral-700 shadow-xs transition-colors hover:bg-neutral-50"
          >
            View Use Cases
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
