---
import LandingLayout from '@layouts/LandingLayout.astro';
import OrganizationSchema from '@components/seo/OrganizationSchema.astro';
import WebSiteSchema from '@components/seo/WebSiteSchema.astro';
import { Hero } from '@components/landing/Hero';
import { LogoBar } from '@components/landing/LogoBar';
import { SocialProof } from '@components/landing/SocialProof';
import { HowItWorks } from '@components/landing/HowItWorks';
import { Features } from '@components/landing/Features';
import { UseCases } from '@components/landing/UseCases';
import { PricingPreview } from '@components/landing/PricingPreview';
import { FAQ } from '@components/landing/FAQ';
import FAQSchema from '@components/seo/FAQSchema.astro';
import { FinalCTA } from '@components/shared/FinalCTA';
import { faqs } from '@data/faqs';

const displayedFaqs = faqs.slice(0, 8);
---

<LandingLayout
  description="Transform API endpoints into real-time event streams with intelligent polling, field-level change detection, and reliable event delivery."
>
  <Fragment slot="head">
    <OrganizationSchema />
    <WebSiteSchema />
  </Fragment>

  <Hero />
  <LogoBar />
  <SocialProof />
  <HowItWorks />
  <Features />
  <UseCases />
  <PricingPreview />
  <FAQSchema items={displayedFaqs.map((faq) => ({ question: faq.question, answer: faq.answer }))} />
  <FAQ />
  <FinalCTA />
</LandingLayout>
